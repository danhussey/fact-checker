# xAI API key for Grok (claim extraction + fact-checking)
XAI_API_KEY=xai-...

# Deepgram API key for real-time streaming transcription
DEEPGRAM_API_KEY=...

# OpenAI API key for Whisper transcription (legacy fallback)
OPENAI_API_KEY=sk-...

# Sentry observability (optional)
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_TRACES_SAMPLE_RATE=0.1
NEXT_PUBLIC_SENTRY_REPLAYS_SESSION_SAMPLE_RATE=0.1
NEXT_PUBLIC_SENTRY_REPLAYS_ON_ERROR_SAMPLE_RATE=1.0

# Transcript diagnostics are included in Sentry breadcrumbs and feedback by default.
# Set to "false" to keep only counts, lengths, verdicts, and technical metadata.
NEXT_PUBLIC_ENABLE_TRANSCRIPT_DIAGNOSTICS=true
NEXT_PUBLIC_TRANSCRIPT_DIAGNOSTIC_MAX_CHARS=4000

# Session Recording (optional, dev only)
# Set to "true" to record transcripts and fact-checks to Vercel KV
RECORD_SESSIONS=false

# Vercel KV (auto-populated when KV is added to project)
# KV_REST_API_URL=
# KV_REST_API_TOKEN=

# Admin secret for accessing /api/sessions endpoint
SESSIONS_SECRET=your-secret-here
